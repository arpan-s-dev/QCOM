# Copy to runtime/.env and fill in. Never commit .env.

# Qualcomm AI Engine Direct SDK root (directory containing QNN_README.txt)
QNN_SDK_ROOT=$HOME/qnn/2.37.0/qairt/2.37.0.250724

# Android NDK 26c (r26c)
ANDROID_NDK_ROOT=$HOME/Android/Sdk/ndk/26.2.11394342
ANDROID_NDK_HOME=$ANDROID_NDK_ROOT

# ExecuTorch source (cloned by setup_wsl.sh)
EXECUTORCH_ROOT=$HOME/src/executorch

# Target SoC for export scripts
QCOM_CHIPSET=SM8750

# adb device serial (optional; leave empty for default device)
ADB_SERIAL=

# On-device staging dir
DEVICE_DIR=/data/local/tmp/lodestar
